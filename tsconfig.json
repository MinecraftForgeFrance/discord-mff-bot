{
    "compilerOptions": {
        "target": "es2022",
        "module": "node16",
        "moduleResolution": "Node16",
        "outDir": "dist",
        "rootDir": "./src",
        "sourceMap": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "verbatimModuleSyntax": true,
        "strict": true,
        "skipLibCheck": true,
        "lib": [
            "es2022"
        ]
    },
    "include": [
        "./src/**/*.ts",
        "./test/**/*.ts"
    ],
    "exclude": [
        "./node_modules"
    ],
    "ts-node": {
        "transpileOnly": true,
        "files": true
    }
}
